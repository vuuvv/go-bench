{
  "name": "go-bench",
  "displayName": "Go Bench",
  "description": "Run Go table-driven test cases from CodeLens and the VS Code Test Explorer.",
  "version": "0.0.7",
  "publisher": "vuuvv",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vuuvv/go-bench.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "go",
    "bench",
    "test",
    "tdd",
    "table",
    "driven",
    "tests"
  ],
  "activationEvents": [
    "onLanguage:go",
    "workspaceContains:**/*_test.go",
    "onView:goBench.sidebar.files",
    "onView:goBench.sidebar.tests",
    "onView:goBench.sidebar.runAndDebug"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "goBench.noop",
        "title": "Go Bench: No-op"
      },
      {
        "command": "goBench.runTest",
        "title": "Go Bench: Run Test"
      },
      {
        "command": "goBench.debugTest",
        "title": "Go Bench: Debug Test"
      },
      {
        "command": "goBench.refreshTestTree",
        "title": "Go Bench: Refresh Test Tree"
      },
      {
        "command": "goBench.refreshCurrentFileTestTree",
        "title": "Go Bench: Refresh Current File Test Tree"
      },
      {
        "command": "goBench.toggleTestTreeMode",
        "title": "Go Bench: Toggle Test Tree Mode"
      },
      {
        "command": "goBench.toggleTestTreeModeFromGoBench",
        "title": "Go Bench Tree Active: Switch to Standard Go Tree",
        "icon": "$(beaker)"
      },
      {
        "command": "goBench.toggleTestTreeModeFromStandardGo",
        "title": "Standard Go Tree Active: Switch to Go Bench Tree",
        "icon": "$(symbol-method)"
      },
      {
        "command": "goBench.sidebar.refreshFiles",
        "title": "Go Bench: Refresh Files",
        "icon": "$(refresh)"
      },
      {
        "command": "goBench.sidebar.refreshTests",
        "title": "Go Bench: Refresh Tests",
        "icon": "$(refresh)"
      },
      {
        "command": "goBench.sidebar.files.open",
        "title": "Go Bench: Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "goBench.sidebar.files.newFile",
        "title": "Go Bench: New File",
        "icon": "$(new-file)"
      },
      {
        "command": "goBench.sidebar.files.newFolder",
        "title": "Go Bench: New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "goBench.sidebar.files.rename",
        "title": "Go Bench: Rename",
        "icon": "$(edit)"
      },
      {
        "command": "goBench.sidebar.files.delete",
        "title": "Go Bench: Delete",
        "icon": "$(trash)"
      },
      {
        "command": "goBench.sidebar.files.reveal",
        "title": "Go Bench: Reveal in OS",
        "icon": "$(folder-opened)"
      },
      {
        "command": "goBench.sidebar.files.copyRelativePath",
        "title": "Go Bench: Copy Relative Path"
      },
      {
        "command": "goBench.sidebar.files.copyAbsolutePath",
        "title": "Go Bench: Copy Absolute Path"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "goBench.sidebar",
          "title": "Go Bench",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "goBench.sidebar": [
        {
          "id": "goBench.sidebar.files",
          "name": "Files",
          "type": "tree",
          "when": "config.goBench.sidebar.enabled && config.goBench.sidebar.files.enabled"
        },
        {
          "id": "goBench.sidebar.tests",
          "name": "Tests",
          "type": "tree",
          "when": "config.goBench.sidebar.enabled && config.goBench.sidebar.tests.enabled"
        },
        {
          "id": "goBench.sidebar.runAndDebug",
          "name": "Run and Debug",
          "type": "tree",
          "when": "config.goBench.sidebar.enabled && config.goBench.sidebar.runnables.enabled"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "goBench.sidebar.refreshFiles",
          "when": "view == goBench.sidebar.files",
          "group": "navigation"
        },
        {
          "command": "goBench.sidebar.files.newFile",
          "when": "view == goBench.sidebar.files",
          "group": "navigation@1"
        },
        {
          "command": "goBench.sidebar.files.newFolder",
          "when": "view == goBench.sidebar.files",
          "group": "navigation@2"
        },
        {
          "command": "goBench.sidebar.refreshTests",
          "when": "view == goBench.sidebar.tests",
          "group": "navigation"
        },
        {
          "command": "goBench.toggleTestTreeModeFromGoBench",
          "when": "view == workbench.view.testing && goBench.testTreeMode.goBench",
          "group": "navigation"
        },
        {
          "command": "goBench.toggleTestTreeModeFromStandardGo",
          "when": "view == workbench.view.testing && goBench.testTreeMode.standardGo",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "goBench.sidebar.files.open",
          "when": "view == goBench.sidebar.files && viewItem == goBenchFile",
          "group": "inline@0"
        },
        {
          "command": "goBench.sidebar.files.newFile",
          "when": "view == goBench.sidebar.files && (viewItem == goBenchFolder || viewItem == goBenchWorkspaceFolder)",
          "group": "inline@1"
        },
        {
          "command": "goBench.sidebar.files.newFolder",
          "when": "view == goBench.sidebar.files && (viewItem == goBenchFolder || viewItem == goBenchWorkspaceFolder)",
          "group": "inline@2"
        },
        {
          "command": "goBench.sidebar.files.rename",
          "when": "view == goBench.sidebar.files && (viewItem == goBenchFile || viewItem == goBenchFolder)",
          "group": "inline@3"
        },
        {
          "command": "goBench.sidebar.files.delete",
          "when": "view == goBench.sidebar.files && (viewItem == goBenchFile || viewItem == goBenchFolder)",
          "group": "inline@4"
        },
        {
          "command": "goBench.sidebar.files.reveal",
          "when": "view == goBench.sidebar.files",
          "group": "navigation"
        },
        {
          "command": "goBench.sidebar.files.copyRelativePath",
          "when": "view == goBench.sidebar.files",
          "group": "navigation@1"
        },
        {
          "command": "goBench.sidebar.files.copyAbsolutePath",
          "when": "view == goBench.sidebar.files",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Go Bench",
      "properties": {
        "goBench.tableTests.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable table-driven test discovery for Go test files."
        },
        "goBench.tableTests.nameFields": {
          "type": "array",
          "default": [
            "name",
            "desc",
            "caseName",
            "title"
          ],
          "items": {
            "type": "string"
          },
          "description": "Struct fields that can provide stable table-driven subtest names."
        },
        "goBench.tableTests.showFunctionRun": {
          "type": "boolean",
          "default": true,
          "description": "Show run entries for whole Go test functions."
        },
        "goBench.tableTests.showCaseRun": {
          "type": "boolean",
          "default": true,
          "description": "Show run entries for resolvable table-driven test cases."
        },
        "goBench.tableTests.testingApi.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the experimental VSCode Testing API tree for Go Bench table-driven tests."
        },
        "goBench.tableTests.testingApi.treeMode": {
          "type": "string",
          "enum": [
            "goBench",
            "standardGo"
          ],
          "default": "goBench",
          "description": "Choose the Test Explorer tree mode. goBench shows the Go Bench tree and hides the standard Go tree; standardGo shows the official Go tree and hides the Go Bench tree."
        },
        "goBench.sidebar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Go Bench Activity Bar sidebar."
        },
        "goBench.sidebar.files.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the Files view in the Go Bench sidebar."
        },
        "goBench.sidebar.tests.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the Tests view in the Go Bench sidebar."
        },
        "goBench.sidebar.runnables.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the Run and Debug view in the Go Bench sidebar."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
