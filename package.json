{
  "name": "go-bench",
  "displayName": "Go Bench",
  "description": "Run Go table-driven test cases from CodeLens and the VS Code Test Explorer.",
  "version": "0.0.1",
  "publisher": "vuuvv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vuuvv/go-bench.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "onLanguage:go",
    "workspaceContains:**/*_test.go"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "goBench.noop",
        "title": "Go Bench: No-op"
      },
      {
        "command": "goBench.runTest",
        "title": "Go Bench: Run Test"
      },
      {
        "command": "goBench.debugTest",
        "title": "Go Bench: Debug Test"
      },
      {
        "command": "goBench.refreshTestTree",
        "title": "Go Bench: Refresh Test Tree"
      },
      {
        "command": "goBench.refreshCurrentFileTestTree",
        "title": "Go Bench: Refresh Current File Test Tree"
      }
    ],
    "configuration": {
      "title": "Go Bench",
      "properties": {
        "goBench.tableTests.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable table-driven test discovery for Go test files."
        },
        "goBench.tableTests.nameFields": {
          "type": "array",
          "default": [
            "name",
            "desc",
            "caseName",
            "title"
          ],
          "items": {
            "type": "string"
          },
          "description": "Struct fields that can provide stable table-driven subtest names."
        },
        "goBench.tableTests.showFunctionRun": {
          "type": "boolean",
          "default": true,
          "description": "Show run entries for whole Go test functions."
        },
        "goBench.tableTests.showCaseRun": {
          "type": "boolean",
          "default": true,
          "description": "Show run entries for resolvable table-driven test cases."
        },
        "goBench.tableTests.testingApi.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the experimental VSCode Testing API tree for Go Bench table-driven tests."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
